---
import { getRelativeLocalePath } from "@i18n/utils";

export interface Props {
  href: string;
  className?: string;
  ariaLabel?: string;
  title?: string;
  disabled?: boolean;
}

function isExternalLink(url: string) {
  return URL.canParse(url);
}

let { href, className = "", ariaLabel, title, disabled = false } = Astro.props;

if (!isExternalLink(href)) {
  href = getRelativeLocalePath(Astro.currentLocale, href);
}
---

{
  disabled ? (
    <span
      class:list={["group inline-block", className]}
      title={title}
      aria-disabled={disabled}
    >
      <slot />
    </span>
  ) : (
    <a
      {href}
      class:list={["group inline-block hover:text-skin-accent", className]}
      aria-label={ariaLabel}
      title={title}
    >
      <slot />
    </a>
  )
}
